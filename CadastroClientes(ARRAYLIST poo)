import java.util.Scanner;
import java.util.ArrayList;
import java.util.Arrays;

public class Arrays03{
    static ArrayList<String> nome_clientes = new ArrayList<String>();
    static ArrayList<String> descricao_clientes = new ArrayList<String>();
    static int quantidade = 0;
    
    public static void main(String[] args) {
        int opcao;
        Scanner teclado = new Scanner(System.in);
        do {
            System.out.println("\nMenu de opções:");
            System.out.println("\n1 - Cadastrar cliente");
            System.out.println("2 - Listar clientes");
            System.out.println("3 - Buscar cliente");
            System.out.println("4 - Remover cliente");
            System.out.println("0 - Sair");
            System.out.print("Digite a opção desejada:  ");
            opcao = Integer.parseInt(teclado.nextLine());
            
            switch(opcao){
                case 1: cadastrarCliente(teclado); break;
                case 2: listarClientes(); break;
                case 3: buscarCliente(teclado); break;
                case 4: removerCliente(teclado); break;
                case 0: System.out.println("Saindo do programa..."); break;
                default: System.out.println("Opção inválida. Tente novamente.");
            }

        } while (opcao != 0);
        teclado.close();
    }
    static void cadastrarCliente(Scanner teclado){
        System.out.println("Nome do cliente: ");
        nome_clientes.add(teclado.nextLine());
        System.out.println("Descrição do cliente: ");
        descricao_clientes.add(teclado.nextLine());
        }
    static void listarClientes(){
        if (nome_clientes.isEmpty()) {
            System.out.println("Nenhum cliente cadastrado.");
            return;
        }
        System.out.println("\nLista de clientes:");
        for (int i = 0; i < nome_clientes.size(); i++) {
            System.out.println((i + 1) + ". " + nome_clientes.get(i) + " - " + descricao_clientes.get(i));
        }
    }
    static void buscarCliente(Scanner teclado){
        System.out.println("\nNome:");
        String nomeBusca = teclado.nextLine();
        for (int i = 0; i < nome_clientes.size(); i++) {
            if (nome_clientes.get(i).equalsIgnoreCase(nomeBusca)) {
                System.out.println((i + 1) + ". " + nome_clientes.get(i) + " - " + descricao_clientes.get(i));
                return;
            }
        }
        System.out.println("Cliente não encontrado: " + nomeBusca);

    }
    static void removerCliente(Scanner teclado){
        System.out.println("\nNome do cliente a remover:");
        String nomeRemover = teclado.nextLine();
        for (int i = 0; i < nome_clientes.size(); i++) {
            if (nome_clientes.get(i).equalsIgnoreCase(nomeRemover)) {
                nome_clientes.remove(i);
                descricao_clientes.remove(i);
                System.out.println("Cliente removido com sucesso!");
                return;
            }
        }
        System.out.println("Cliente não encontrado: " + nomeRemover);
    }
}
